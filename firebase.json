{
  "functions": {
    "source": "PULSE-WORLD/PULSE-WORLD-HEARTBEAT-2",
    "codebase": "default",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ],
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" install",
      "npm --prefix \"$RESOURCE_DIR\" run lint || echo \"Lint skipped\""
    ]
  }
}
